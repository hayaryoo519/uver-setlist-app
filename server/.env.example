# Database Configuration
# DATABASE_URL=postgres://user:password@localhost:5432/uver_app_db

# Security
# JWT_SECRET=your_complex_secret_key

# External APIs
SETLIST_FM_API_KEY=your_setlist_fm_api_key_here

# Email Configuration (Gmail App Password recommended)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# Application URL (for email links)
# APP_URL=https://uver-setlist-archive.org

# Push Notifications (generate with: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=your_vapid_public_key
# VAPID_PRIVATE_KEY=your_vapid_private_key
# VAPID_SUBJECT=mailto:admin@uver-setlist-archive.org

# Google Stitch MCP
# GOOGLE_STITCH_API_KEY=your_google_stitch_api_key_here

# Spotify API (Optional)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/spotify/callback

# Google API (YouTube Music) (Optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/youtube/callback

# Encryption Key (Required for Spotify/YouTube tokens - 32 bytes hex)
ENCRYPTION_KEY=your_64_char_hex_key_here
